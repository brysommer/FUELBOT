// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Таблиця пошукових запитів та лімітів ціни
model SearchConfig {
  id           Int      @id @default(autoincrement())
  query        String   // Наприклад: "iPhone 17 Pro", "iPhone 17 Pro Max"
  minPrice     Float    // Поріг знизу, щоб відсікти чохли/коробки (наприклад, 400)
  maxPrice     Float    // Максимальний поріг Buy It Now (наприклад, 850)
  currency     String   @default("EUR")
  isActive     Boolean  @default(true)
  comment      String?  // Нотатка для себе (наприклад: "Шукаю під замовлення")

  @@map("search_configs")
}

// 2. Таблиця для дедуплікації (щоб лоти не присилалися повторно)
model TrackedItem {
  id          String   @id // eBay itemId (String, бо в eBay це довгі числові ID, які можуть вийти за межі стандартного Integer)
  title       String
  price       Float
  currency    String
  url         String
  marketplace String   // Наприклад: EBAY_DE, EBAY_PL
  createdAt   DateTime @default(now())

  @@map("tracked_items")
}

// 3. Глобальні налаштування системи (щоб міняти розклад роботи без передеплою)
model AppConfig {
  key         String   @id // Наприклад: "WORK_START_HOUR", "WORK_END_HOUR"
  value       String   // Наприклад: "9", "23"
  description String?

  @@map("app_configs")
}